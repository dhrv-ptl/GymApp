# Supabase: Required for database and authentication.
# Get these from your Supabase Project Settings > API.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# GEMINI_API_KEY: Optional. Required only if AI-powered features are enabled.
# Obtain an API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: The base URL of the running application.
# Used for OAuth callbacks and self-referential API links.
# Example: http://localhost:3000 for local development.
APP_URL="http://localhost:3000"
